{
  "manifest_version": 3,
  "name": "Request Diff",
  "version": "1.0.0",
  "description": "API 응답을 캡처하고 비교하세요.",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js"
  },
  "devtools_page": "devtools/devtools.html",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
